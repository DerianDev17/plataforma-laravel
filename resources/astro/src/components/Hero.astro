---
const highlights = [
  'Horarios flexibles',
  'Presencial y online',
  'Acompanamiento completo',
];
---

<section id="inicio" class="relative isolate flex min-h-[78svh] items-center overflow-hidden pt-24 text-white">
  <img
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    src="/storage/img/slider1-1200x700.jpg"
    alt="Estudiantes en preparacion preuniversitaria"
    loading="eager"
  />
  <div class="absolute inset-0 -z-10 bg-zinc-950/62"></div>

  <div class="mx-auto grid w-full max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8">
    <div class="max-w-3xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.28em] text-orange-200">Quito, Ecuador</p>
      <h1 class="text-4xl font-black leading-tight sm:text-6xl lg:text-7xl">Semilla Digital</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-100 sm:text-xl">
        Preparacion academica para ingreso a universidades publicas, privadas y escuelas militares.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex items-center justify-center rounded-lg bg-orange-600 px-6 py-3 text-base font-bold text-white shadow-lg shadow-orange-950/20 transition hover:bg-orange-500" href="#contacto">
          Solicitar informacion
        </a>
        <a class="inline-flex items-center justify-center rounded-lg border border-white/70 px-6 py-3 text-base font-bold text-white transition hover:bg-white hover:text-zinc-950" href="/login">
          Iniciar sesion
        </a>
      </div>
    </div>

    <div class="hidden content-end gap-3 sm:grid lg:justify-end">
      {highlights.map((item) => (
        <div class="rounded-lg border border-white/20 bg-white/12 px-5 py-4 text-base font-bold uppercase tracking-[0.12em] backdrop-blur-sm">
          {item}
        </div>
      ))}
    </div>
  </div>
</section>
