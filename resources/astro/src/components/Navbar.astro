---
const navItems = [
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/60 bg-white/88 backdrop-blur-md">
  <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8" aria-label="Navegacion principal">
    <a class="flex items-center gap-3" href="#inicio" aria-label="Semilla Digital">
      <img class="h-12 w-auto" src="/storage/img/logo-horizontal.png" alt="Semilla Digital" loading="eager" />
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {navItems.map((item) => (
        <a class="text-sm font-semibold uppercase tracking-[0.22em] text-zinc-800 transition hover:text-orange-600" href={item.href}>
          {item.label}
        </a>
      ))}
      <a class="rounded-lg bg-zinc-950 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-700" href="/login">
        Iniciar sesion
      </a>
    </div>

    <details class="group relative md:hidden">
      <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-lg border border-zinc-200 bg-white text-zinc-900 shadow-sm">
        <span class="sr-only">Abrir menu</span>
        <svg class="h-5 w-5 group-open:hidden" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <svg class="hidden h-5 w-5 group-open:block" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-3 w-64 rounded-lg border border-zinc-200 bg-white p-3 shadow-xl">
        {navItems.map((item) => (
          <a class="block rounded-md px-3 py-3 text-sm font-semibold text-zinc-800 hover:bg-orange-50 hover:text-orange-700" href={item.href}>
            {item.label}
          </a>
        ))}
        <a class="mt-2 block rounded-lg bg-zinc-950 px-3 py-3 text-center text-sm font-semibold text-white" href="/login">
          Iniciar sesion
        </a>
      </div>
    </details>
  </nav>
</header>
