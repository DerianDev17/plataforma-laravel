---
const points = [
  'Preparacion por materias clave para el examen de admision.',
  'Docentes con clases guiadas y refuerzo constante.',
  'Seguimiento antes, durante y despues del proceso.',
];
---

<section id="nosotros" class="border-y border-zinc-200 bg-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.24em] text-orange-700">Nosotros</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-zinc-950 sm:text-4xl">Preparacion enfocada en ingreso universitario</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      {points.map((point) => (
        <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-5">
          <p class="text-base font-semibold leading-7 text-zinc-800">{point}</p>
        </div>
      ))}
    </div>
  </div>
</section>
