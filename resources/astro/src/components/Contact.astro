---
const contacts = [
  { label: '025 130 777', href: 'tel:025130777' },
  { label: '+593 96 327 7997', href: 'https://wa.me/593963277997' },
  { label: 'info@semilladigital.com', href: 'mailto:info@semilladigital.com' },
];
---

<section id="contacto" class="bg-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.24em] text-orange-700">Contacto</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-zinc-950 sm:text-4xl">Av. America N29-106 y Acuna</h2>
      <p class="mt-4 text-lg leading-8 text-zinc-600">Quito, Ecuador</p>
      <div class="mt-8 grid gap-3">
        {contacts.map((item) => (
          <a class="rounded-lg border border-zinc-200 px-5 py-4 text-lg font-bold text-zinc-900 transition hover:border-orange-600 hover:text-orange-700" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
            {item.label}
          </a>
        ))}
      </div>
    </div>
    <div class="min-h-96 overflow-hidden rounded-lg border border-zinc-200 bg-zinc-100 shadow-sm">
      <iframe
        class="h-full min-h-96 w-full"
        title="Ubicacion Semilla Digital"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        src="https://maps.google.com/maps?width=600&height=400&hl=es&q=Av.%20America%20N29-106%20y%20Acuna%20Quito%20Ecuador&t=&z=14&ie=UTF8&iwloc=B&output=embed">
      </iframe>
    </div>
  </div>
</section>
